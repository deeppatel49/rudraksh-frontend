<%
const resolvedAdminBaseUrl = typeof adminBaseUrl !== "undefined" && adminBaseUrl ? adminBaseUrl : "";
%>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Sign Up - Rudraksh Pharmacy</title>
    <link rel="stylesheet" href="<%= resolvedAdminBaseUrl %>/admin.css">
</head>
<body class="auth-page">
    <div class="auth-shell">
        <section class="auth-hero">
            <div class="auth-brand">
                <div class="brand-mark">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                    </svg>
                </div>
                <div class="auth-brand-copy">
                    <h1>Rudraksh Backend</h1>
                    <p>Admin account onboarding</p>
                </div>
            </div>

            <div>
                <span class="metric-label">Access setup</span>
                <h2>Create a backend admin account with less guesswork.</h2>
                <p>This setup flow now matches the admin console UI and makes the first login path clearer for new operators.</p>
            </div>

            <div class="summary-grid">
                <div class="metric-card">
                    <div class="metric-label">What you unlock</div>
                    <strong class="metric-value">CMS</strong>
                    <p>Edit homepage and about-page content from backend forms instead of changing source files.</p>
                </div>
                <div class="metric-card">
                    <div class="metric-label">What you monitor</div>
                    <strong class="metric-value">Ops</strong>
                    <p>Inspect products, messages, reviews, prescriptions, and customers from one backend-only shell.</p>
                </div>
            </div>

            <ul class="auth-list">
                <li>Cleaner validation makes signup failures easier to fix before submission.</li>
                <li>Shared admin design language means onboarding and day-to-day work feel connected.</li>
                <li>After signup, the dashboard becomes the default landing experience.</li>
            </ul>
        </section>

        <section class="auth-card">
            <div class="auth-card-body">
                <div class="auth-card-head">
                    <span class="page-badge">Create account</span>
                    <h3>Admin sign up</h3>
                    <p>Set up backend admin access for the operations console.</p>
                </div>

                <% if (errorMessage) { %>
                    <div class="flash error">
                        <div>
                            <strong>Account creation failed</strong>
                            <p><%= errorMessage %></p>
                        </div>
                    </div>
                <% } %>

                <% if (successMessage) { %>
                    <div class="flash success">
                        <div>
                            <strong>Account created</strong>
                            <p><%= successMessage %></p>
                        </div>
                    </div>
                <% } %>

                <form id="signupForm" method="POST" class="auth-form">
                    <div class="auth-input-row">
                        <label class="field-label" for="fullName">Full name</label>
                        <input class="auth-input" type="text" id="fullName" name="fullName" placeholder="John Doe" required>
                        <div class="error-text"></div>
                    </div>

                    <div class="auth-input-row">
                        <label class="field-label" for="email">Email address</label>
                        <input class="auth-input" type="email" id="email" name="email" placeholder="admin@rudraksh.com" required>
                        <div class="error-text"></div>
                    </div>

                    <div class="auth-input-row">
                        <label class="field-label" for="password">Password</label>
                        <div class="password-wrap">
                            <input class="auth-input" type="password" id="password" name="password" placeholder="Enter password" required>
                            <button type="button" class="icon-button" id="togglePassword" aria-label="Show password" aria-pressed="false">
                                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                </svg>
                            </button>
                        </div>
                        <div class="error-text"></div>
                    </div>

                    <div class="auth-input-row">
                        <label class="field-label" for="confirmPassword">Confirm password</label>
                        <div class="password-wrap">
                            <input class="auth-input" type="password" id="confirmPassword" name="confirmPassword" placeholder="Confirm password" required>
                            <button type="button" class="icon-button" id="toggleConfirmPassword" aria-label="Show confirm password" aria-pressed="false">
                                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                </svg>
                            </button>
                        </div>
                        <div class="error-text"></div>
                    </div>

                    <button type="submit" id="submitBtn" class="btn">
                        <span class="loading-spinner"></span>
                        Create account
                    </button>
                </form>

                <div class="auth-footer">
                    Already have an account? <a href="<%= resolvedAdminBaseUrl %>/admin/login">Sign in here</a>
                </div>
            </div>
        </section>
    </div>

    <script nonce="<%= cspNonce %>">
        const form = document.getElementById("signupForm");
        const fullNameInput = document.getElementById("fullName");
        const emailInput = document.getElementById("email");
        const passwordInput = document.getElementById("password");
        const confirmPasswordInput = document.getElementById("confirmPassword");
        const submitBtn = document.getElementById("submitBtn");
        const spinner = submitBtn.querySelector(".loading-spinner");
        let isSubmitting = false;

        function toggleVisibility(buttonId, input) {
            const button = document.getElementById(buttonId);
            function setVisible(isVisible) {
                input.type = isVisible ? "text" : "password";
                button.classList.toggle("active", isVisible);
                button.setAttribute("aria-pressed", isVisible ? "true" : "false");
                button.setAttribute("aria-label", isVisible ? "Hide password" : "Show password");
            }
            setVisible(false);
            button.addEventListener("click", () => {
                setVisible(input.type === "password");
            });
        }

        toggleVisibility("togglePassword", passwordInput);
        toggleVisibility("toggleConfirmPassword", confirmPasswordInput);

        const inputs = [fullNameInput, emailInput, passwordInput, confirmPasswordInput];

        function getErrorTextElement(input) {
            return input.closest(".auth-input-row")?.querySelector(".error-text");
        }

        function showError(input, message) {
            input.classList.add("error");
            getErrorTextElement(input).textContent = message;
        }

        function clearError(input) {
            input.classList.remove("error");
            const errorEl = getErrorTextElement(input);
            if (errorEl) errorEl.textContent = "";
        }

        form.addEventListener("submit", (event) => {
            event.preventDefault();
            if (isSubmitting) return;

            inputs.forEach(clearError);

            const fullName = fullNameInput.value.trim();
            const email = emailInput.value.trim();
            const password = passwordInput.value;
            const confirmPassword = confirmPasswordInput.value;
            let isValid = true;

            if (!fullName) {
                showError(fullNameInput, "Full name is required.");
                isValid = false;
            } else if (fullName.length < 2) {
                showError(fullNameInput, "Use at least 2 characters.");
                isValid = false;
            }

            if (!email) {
                showError(emailInput, "Email is required.");
                isValid = false;
            } else if (!email.match(/^[^\s@]+@[^\s@]+\.[^\s@]+$/)) {
                showError(emailInput, "Enter a valid email address.");
                isValid = false;
            }

            if (!password) {
                showError(passwordInput, "Password is required.");
                isValid = false;
            } else if (password.length < 6) {
                showError(passwordInput, "Use at least 6 characters.");
                isValid = false;
            }

            if (!confirmPassword) {
                showError(confirmPasswordInput, "Confirm your password.");
                isValid = false;
            } else if (password !== confirmPassword) {
                showError(confirmPasswordInput, "Passwords do not match.");
                isValid = false;
            }

            if (!isValid) return;

            isSubmitting = true;
            submitBtn.disabled = true;
            spinner.classList.add("show");
            form.submit();
        });

        inputs.forEach((input) => {
            input.addEventListener("input", () => clearError(input));
        });
    </script>
</body>
</html>
