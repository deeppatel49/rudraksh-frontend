<%
const resolvedAdminBaseUrl = typeof adminBaseUrl !== "undefined" && adminBaseUrl ? adminBaseUrl : "";
const pageTitle = "Customer Chat";
const activeView = "chat-box";
const safeErrorMessage = typeof errorMessage !== "undefined" ? errorMessage : "";
const safeSuccessMessage = typeof successMessage !== "undefined" ? successMessage : "";
const composer = chatComposer || {};
const hasTargetUser = Boolean(composer.userId || composer.email || composer.phone);
%>
<%- include("partials/admin-shell-start", { pageTitle, activeView, resolvedAdminBaseUrl, adminUser, cspNonce }) %>

<section class="page-head">
    <div class="page-copy">
        <span class="page-badge">💬 Customer Chat</span>
        <h2 class="page-title" id="chatTitle">Chat Window</h2>
        <p id="chatSubtitle">Send messages directly to customers</p>
    </div>
    <div class="page-actions">
        <a class="ghost-btn" href="<%= resolvedAdminBaseUrl %>/admin/chat-box">← Back to Chat Box</a>
    </div>
</section>

<% if (safeErrorMessage) { %>
    <div class="message error">
        <div>
            <strong>❌ Error</strong>
            <p><%= safeErrorMessage %></p>
        </div>
    </div>
<% } %>

<% if (safeSuccessMessage) { %>
    <div class="message success">
        <div>
            <strong>✅ Success</strong>
            <p><%= safeSuccessMessage %></p>
        </div>
    </div>
<% } %>

<div id="noCustomerState" style="display: <%= hasTargetUser ? 'none' : 'block' %>;" class="chat-empty-panel">
    <h3>No Customer Selected</h3>
    <p>Go back to Chat Box and click "Open Chat" on a customer to start messaging.</p>
</div>

<div id="chatContainer" style="display: <%= hasTargetUser ? 'block' : 'none' %>;" class="chat-panel">
    <!-- Messages Area -->
    <div class="chat-messages-wrapper">
        <div id="chatThread" class="chat-messages">
            <div class="message-placeholder">Loading messages...</div>
        </div>
    </div>

    <!-- Send Message Form -->
    <form id="sellerChatForm" class="chat-form-wrapper" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="userId" value="">
        <input type="hidden" name="email" value="">
        <input type="hidden" name="phone" value="">
        <input type="hidden" name="name" value="">

        <div class="form-field">
            <textarea 
                name="message" 
                class="message-input" 
                placeholder="Type your message here..."></textarea>
        </div>

        <div class="form-actions">
            <input type="file" name="attachment" accept="image/*,video/*" class="file-input" style="display:none;" id="fileInput">
            <label for="fileInput" class="btn-icon" title="Attach image or video" style="cursor: pointer; user-select: none;">📎</label>
            <button type="submit" class="btn-primary" id="sendBtn">📤 Send</button>
        </div>
    </form>
</div>

<style>
    * {
        box-sizing: border-box;
    }

    .chat-empty-panel {
        background: #ffffff;
        border: 2px dashed #d1d5db;
        border-radius: 16px;
        padding: 60px 40px;
        text-align: center;
        margin: 20px 0;
    }

    .chat-empty-panel h3 {
        font-size: 24px;
        color: #1a1a1a;
        margin-bottom: 12px;
    }

    .chat-empty-panel p {
        font-size: 16px;
        color: #6b7280;
    }

    .chat-panel {
        display: flex;
        flex-direction: column;
        height: 85vh;
        background: #ffffff;
        border-radius: 16px;
        border: 1px solid #e5e7eb;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        margin: 20px 0;
    }

    .chat-messages-wrapper {
        flex: 1;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        background: linear-gradient(to bottom, #f9fafb, #ffffff);
        border-bottom: 1px solid #e5e7eb;
    }

    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .message-placeholder {
        text-align: center;
        color: #9ca3af;
        padding: 40px 20px;
        font-size: 16px;
    }

    /* Message Bubbles */
    .chat-message {
        display: flex;
        flex-direction: column;
        gap: 6px;
        animation: messageSlide 0.3s ease-out;
    }

    @keyframes messageSlide {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .chat-message.from-customer {
        align-items: flex-start;
    }

    .chat-message.from-seller {
        align-items: flex-end;
    }

    .message-bubble {
        max-width: 70%;
        padding: 14px 18px;
        border-radius: 16px;
        word-wrap: break-word;
        line-height: 1.5;
    }

    .message-bubble.customer {
        background: #e5e7eb;
        color: #000000;
        border: 1px solid #d1d5db;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
    }

    .message-bubble.seller {
        background: linear-gradient(135deg, #0084ff 0%, #0066cc 100%);
        color: #ffffff;
        box-shadow: 0 2px 8px rgba(0, 132, 255, 0.3);
    }

    .message-sender {
        font-size: 12px;
        font-weight: 700;
        margin-bottom: 4px;
        display: block;
    }

    .message-bubble.customer .message-sender {
        color: #1a73e8;
    }

    .message-bubble.seller .message-sender {
        color: rgba(255, 255, 255, 0.9);
    }

    .message-text {
        font-size: 15px;
        font-weight: 500;
        margin: 8px 0;
        white-space: pre-wrap;
    }

    .message-attachment {
        margin-top: 10px;
    }

    .message-attachment img,
    .message-attachment video {
        max-width: 280px;
        width: 100%;
        border-radius: 10px;
        display: block;
        border: 1px solid rgba(0, 0, 0, 0.12);
        background: #000;
    }

    .message-attachment-link {
        display: inline-block;
        margin-top: 6px;
        font-size: 12px;
        color: inherit;
        text-decoration: underline;
        opacity: 0.9;
    }

    .message-time {
        font-size: 11px;
        margin-top: 6px;
        opacity: 0.7;
    }

    .message-bubble.customer .message-time {
        color: #6b7280;
    }

    .message-bubble.seller .message-time {
        color: rgba(255, 255, 255, 0.75);
    }

    .msg-delete-btn {
        position: absolute;
        top: 8px;
        left: 8px;
        background: none;
        border: none;
        font-size: 16px;
        cursor: pointer;
        opacity: 0;
        transition: opacity 0.2s ease, transform 0.2s ease;
        padding: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 6px;
    }

    .message-bubble {
        position: relative;
    }

    .message-bubble:hover .msg-delete-btn {
        opacity: 0.7;
    }

    .msg-delete-btn:hover {
        opacity: 1 !important;
        background: rgba(0, 0, 0, 0.2);
        transform: scale(1.1);
    }

    .msg-delete-btn:active {
        transform: scale(0.95);
    }

    @keyframes fadeOut {
        from {
            opacity: 1;
            transform: translateX(0);
        }
        to {
            opacity: 0;
            transform: translateX(20px);
        }
    }

    /* Form Area */
    .chat-form-wrapper {
        padding: 20px 24px;
        background: #ffffff;
        border-top: 1px solid #e5e7eb;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .form-field {
        display: flex;
        gap: 12px;
    }

    .message-input {
        flex: 1;
        padding: 14px 16px;
        border: 2px solid #d1d5db;
        border-radius: 12px;
        font-family: inherit;
        font-size: 15px;
        color: #000000;
        background: #ffffff;
        resize: none;
        max-height: 120px;
        transition: all 0.2s ease;
    }

    .message-input:focus {
        outline: none;
        border-color: #0084ff;
        box-shadow: 0 0 0 4px rgba(0, 132, 255, 0.15);
    }

    .message-input::placeholder {
        color: #9ca3af;
    }

    .form-actions {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
    }

    .btn-icon {
        width: 44px;
        height: 44px;
        border: 2px solid #d1d5db;
        background: #ffffff;
        border-radius: 10px;
        font-size: 20px;
        cursor: pointer;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        user-select: none;
    }

    .btn-icon:hover {
        border-color: #0084ff;
        background: #f0f9ff;
    }

    .btn-primary {
        padding: 12px 24px;
        background: linear-gradient(135deg, #0084ff 0%, #0066cc 100%);
        color: #ffffff;
        border: none;
        border-radius: 10px;
        font-weight: 700;
        font-size: 15px;
        cursor: pointer;
        transition: all 0.2s ease;
        box-shadow: 0 2px 8px rgba(0, 132, 255, 0.3);
    }

    .btn-primary:hover:not(:disabled) {
        background: linear-gradient(135deg, #0073e6 0%, #0055aa 100%);
        box-shadow: 0 4px 12px rgba(0, 132, 255, 0.4);
        transform: translateY(-1px);
    }

    .btn-primary:active:not(:disabled) {
        transform: translateY(0);
    }

    .btn-primary:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    @media (max-width: 768px) {
        .chat-panel {
            height: calc(100vh - 200px);
        }

        .message-bubble {
            max-width: 85%;
        }

        .message-input {
            font-size: 16px;
        }
    }
</style>

<script nonce="<%= cspNonce %>">
    const resolvedAdminBaseUrl = "<%= resolvedAdminBaseUrl %>";
    const urlParams = new URLSearchParams(window.location.search);
    const userId = urlParams.get("userId");
    const email = urlParams.get("email");
    const phone = urlParams.get("phone");
    const customerName = urlParams.get("name") || "Customer";

    function initializeChat() {
        if (!userId && !email && !phone) {
            document.getElementById("noCustomerState").style.display = "block";
            document.getElementById("chatContainer").style.display = "none";
            return;
        }

        document.getElementById("noCustomerState").style.display = "none";
        document.getElementById("chatContainer").style.display = "flex";
        document.getElementById("chatTitle").textContent = `Chat with ${customerName}`;

        const form = document.getElementById("sellerChatForm");
        form.querySelector('input[name="userId"]').value = userId || "";
        form.querySelector('input[name="email"]').value = email || "";
        form.querySelector('input[name="phone"]').value = phone || "";
        form.querySelector('input[name="name"]').value = customerName || "";
        form.action = resolvedAdminBaseUrl + "/admin/customer-chat/send";

        loadMessages();
    }

    async function loadMessages() {
        try {
            const params = new URLSearchParams();
            if (userId) params.append("userId", userId);
            if (email) params.append("email", email);
            if (phone) params.append("phone", phone);
            if (customerName) params.append("name", customerName);

            const response = await fetch(
                resolvedAdminBaseUrl + "/admin/api/chat/data?" + params.toString(),
                {
                    method: "GET",
                    credentials: "include",
                    headers: { "Accept": "application/json" }
                }
            );

            if (!response.ok) throw new Error("Failed to load messages");

            const result = await response.json();
            if (result.success && result.data) {
                displayMessages(result.data.messages || []);
            }
        } catch (error) {
            console.error("Error:", error);
            document.getElementById("chatThread").innerHTML = 
                `<div class="message-placeholder">❌ Error loading messages</div>`;
        }
    }

    function displayMessages(messages) {
        const chatThread = document.getElementById("chatThread");

        if (!messages || messages.length === 0) {
            chatThread.innerHTML = `<div class="message-placeholder">💬 No messages yet. Send the first message!</div>`;
            return;
        }

        chatThread.innerHTML = messages.map((msg, index) => {
            const isCustomer = msg.senderRole !== "seller";
            const name = msg.senderName || (isCustomer ? msg.name || "Customer" : "Seller");
            const time = msg.createdAt ? new Date(msg.createdAt).toLocaleString("en-IN") : "";
            const text = (msg.message || "").trim();
            const msgId = msg.id || `msg-${index}`;
            const attachment = msg.attachment || null;
            const attachmentUrl = attachment && attachment.url ? String(attachment.url).trim() : "";
            const attachmentMime = attachment && attachment.mimeType ? String(attachment.mimeType).toLowerCase() : "";
            const hasAttachment = Boolean(attachmentUrl);
            const attachmentLower = attachmentUrl.toLowerCase();
            const isImage = hasAttachment && (
                attachmentMime.startsWith("image/") ||
                /\.(jpg|jpeg|png|webp|gif|bmp|svg|heic|heif)(\?|#|$)/.test(attachmentLower)
            );
            const isVideo = hasAttachment && (
                attachmentMime.startsWith("video/") ||
                /\.(mp4|webm|ogg|mov|avi|mkv)(\?|#|$)/.test(attachmentLower)
            );
            const mediaUrl = hasAttachment && attachmentUrl.startsWith("/")
                ? `${resolvedAdminBaseUrl}${attachmentUrl}`
                : attachmentUrl;

            let attachmentHtml = "";
            if (hasAttachment) {
                if (isImage) {
                    attachmentHtml = `
                        <div class="message-attachment">
                            <img src="${mediaUrl}" alt="Attachment" loading="lazy" />
                            <a class="message-attachment-link" href="${mediaUrl}" target="_blank" rel="noopener noreferrer">Open image</a>
                        </div>
                    `;
                } else if (isVideo) {
                    attachmentHtml = `
                        <div class="message-attachment">
                            <video controls preload="metadata" src="${mediaUrl}"></video>
                            <a class="message-attachment-link" href="${mediaUrl}" target="_blank" rel="noopener noreferrer">Open video</a>
                        </div>
                    `;
                } else {
                    attachmentHtml = `
                        <div class="message-attachment">
                            <a class="message-attachment-link" href="${mediaUrl}" target="_blank" rel="noopener noreferrer">Download attachment</a>
                        </div>
                    `;
                }
            }

            return `
                <div class="chat-message ${isCustomer ? 'from-customer' : 'from-seller'}" data-msg-id="${msgId}" data-msg-index="${index}">
                    <div class="message-bubble ${isCustomer ? 'customer' : 'seller'}">
                        <div class="message-sender">${name}</div>
                        ${text && text !== "(no text)" ? `<div class="message-text">${text}</div>` : ''}
                        ${attachmentHtml}
                        <div class="message-time">${time}</div>
                        <button type="button" class="msg-delete-btn" title="Delete message" data-delete-id="${msgId}">🗑️</button>
                    </div>
                </div>
            `;
        }).join("");

        // Attach delete handlers
        document.querySelectorAll(".msg-delete-btn").forEach(btn => {
            btn.addEventListener("click", handleDeleteMessage);
        });

        chatThread.scrollTop = chatThread.scrollHeight;
    }

    function handleDeleteMessage(event) {
        event.preventDefault();
        event.stopPropagation();
        
        const msgId = event.currentTarget.getAttribute("data-delete-id");
        if (!msgId || !confirm("Delete this message?")) return;

        const msgElement = event.currentTarget.closest(".chat-message");
        if (!msgElement) return;

        msgElement.style.opacity = "0.5";
        msgElement.style.pointerEvents = "none";

        // Call backend API to delete message
        fetch(resolvedAdminBaseUrl + "/admin/api/chat/delete", {
            method: "POST",
            credentials: "include",
            headers: {
                "Content-Type": "application/json",
                "Accept": "application/json"
            },
            body: JSON.stringify({ messageId: msgId })
        })
        .then(response => {
            if (!response.ok) throw new Error("Delete failed");
            return response.json();
        })
        .then(result => {
            if (result.success) {
                msgElement.style.animation = "fadeOut 0.3s ease-out";
                setTimeout(() => {
                    msgElement.remove();
                    const remainingMessages = document.querySelectorAll(".chat-message").length;
                    if (remainingMessages === 0) {
                        document.getElementById("chatThread").innerHTML = `<div class="message-placeholder">💬 No messages yet. Send the first message!</div>`;
                    }
                    // Ensure UI is in sync with backend after delete.
                    loadMessages();
                }, 300);
            } else {
                throw new Error(result.error || "Delete failed");
            }
        })
        .catch(error => {
            console.error("Delete error:", error);
            msgElement.style.opacity = "1";
            msgElement.style.pointerEvents = "auto";
            alert("Failed to delete message: " + error.message);
        });
    }

    document.addEventListener("DOMContentLoaded", initializeChat);

    // File input change handler - show selected file name
    document.getElementById("fileInput")?.addEventListener("change", (e) => {
        const fileInput = e.target;
        if (fileInput.files && fileInput.files.length > 0) {
            const fileName = fileInput.files[0].name;
            const attachLabel = document.querySelector('label[for="fileInput"]');
            if (attachLabel) {
                attachLabel.title = `Selected: ${fileName}`;
                attachLabel.style.borderColor = "#0084ff";
                attachLabel.style.background = "#f0f9ff";
            }
        }
    });

    document.getElementById("sellerChatForm")?.addEventListener("submit", (e) => {
        const msg = document.querySelector(".message-input").value.trim();
        const fileInput = document.getElementById("fileInput");
        const hasFile = fileInput && fileInput.files && fileInput.files.length > 0;
        
        if (!msg && !hasFile) {
            e.preventDefault();
            alert("Please type a message or attach an image/video");
            return false;
        }

        // Show sending feedback
        const sendBtn = document.getElementById("sendBtn");
        if (sendBtn) {
            sendBtn.disabled = true;
            sendBtn.textContent = "⏳ Sending...";
        }
    });
</script>

<%- include("partials/admin-shell-end", { cspNonce }) %>