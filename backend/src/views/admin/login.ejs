<%
const resolvedAdminBaseUrl = typeof adminBaseUrl !== "undefined" && adminBaseUrl ? adminBaseUrl : "";
%>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login - Rudraksh Pharmacy</title>
    <link rel="stylesheet" href="<%= resolvedAdminBaseUrl %>/admin.css">
</head>
<body class="auth-page">
    <div class="auth-shell">
        <section class="auth-hero">
            <div class="auth-brand">
                <div class="brand-mark">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                </div>
                <div class="auth-brand-copy">
                    <h1>Rudraksh Backend</h1>
                    <p>Admin operations console</p>
                </div>
            </div>

            <div>
                <span class="metric-label">Secure access</span>
                <h2>Operate the backend with less friction.</h2>
                <p>Review customer messages, update CMS content, inspect backend records, and keep the pharmacy admin workflow fast and consistent.</p>
            </div>

            <div class="summary-grid">
                <div class="metric-card">
                    <div class="metric-label">Connected areas</div>
                    <strong class="metric-value">8</strong>
                    <p>Dashboard, records, and content modules available from one admin shell.</p>
                </div>
                <div class="metric-card">
                    <div class="metric-label">Purpose</div>
                    <strong class="metric-value">Backend</strong>
                    <p>Everything here is scoped to the backend admin only, not the public storefront UI.</p>
                </div>
            </div>

            <ul class="auth-list">
                <li>Manage backend-managed homepage and about-page content without editing code.</li>
                <li>Triages messages and prescriptions from customer submissions in one place.</li>
                <li>Uses the same visual system as the rest of the admin after sign-in.</li>
            </ul>
        </section>

        <section class="auth-card">
            <div class="auth-card-body">
                <div class="auth-card-head">
                    <span class="page-badge">Sign in</span>
                    <h3>Admin login</h3>
                    <p>Enter your backend admin credentials to continue.</p>
                </div>

                <% if (errorMessage) { %>
                    <div class="flash error">
                        <div>
                            <strong>Unable to sign in</strong>
                            <p><%= errorMessage %></p>
                        </div>
                    </div>
                <% } %>

                <% if (successMessage) { %>
                    <div class="flash success">
                        <div>
                            <strong>Account ready</strong>
                            <p><%= successMessage %></p>
                        </div>
                    </div>
                <% } %>

                <form id="loginForm" method="POST" class="auth-form">
                    <div class="auth-input-row">
                        <label class="field-label" for="email">Email address</label>
                        <input class="auth-input" type="email" id="email" name="email" placeholder="admin@rudraksh.com" required>
                        <div class="error-text"></div>
                    </div>

                    <div class="auth-input-row">
                        <label class="field-label" for="password">Password</label>
                        <div class="password-wrap">
                            <input class="auth-input" type="password" id="password" name="password" placeholder="Enter password" required>
                            <button type="button" class="icon-button" id="togglePassword" aria-label="Show password" aria-pressed="false">
                                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                </svg>
                            </button>
                        </div>
                        <div class="error-text"></div>
                    </div>

                    <button type="submit" id="submitBtn" class="btn">
                        <span class="loading-spinner"></span>
                        Sign in
                    </button>
                </form>

                <div class="auth-footer">
                    Need an admin account? <a href="<%= resolvedAdminBaseUrl %>/admin/signup">Create one here</a>
                </div>
            </div>
        </section>
    </div>

    <script nonce="<%= cspNonce %>">
        const form = document.getElementById("loginForm");
        const emailInput = document.getElementById("email");
        const passwordInput = document.getElementById("password");
        const togglePasswordBtn = document.getElementById("togglePassword");
        const submitBtn = document.getElementById("submitBtn");
        const spinner = submitBtn.querySelector(".loading-spinner");
        let isSubmitting = false;

        function getErrorTextElement(input) {
            return input.closest(".auth-input-row")?.querySelector(".error-text");
        }

        function setPasswordVisibility(shouldShow) {
            passwordInput.type = shouldShow ? "text" : "password";
            togglePasswordBtn.classList.toggle("active", shouldShow);
            togglePasswordBtn.setAttribute("aria-pressed", shouldShow ? "true" : "false");
            togglePasswordBtn.setAttribute("aria-label", shouldShow ? "Hide password" : "Show password");
        }

        setPasswordVisibility(false);

        togglePasswordBtn.addEventListener("click", () => {
            setPasswordVisibility(passwordInput.type === "password");
        });

        form.addEventListener("submit", (event) => {
            event.preventDefault();

            if (isSubmitting) return;

            let isValid = true;
            const email = emailInput.value.trim();
            const password = passwordInput.value;

            [emailInput, passwordInput].forEach((input) => {
                input.classList.remove("error");
                const errorEl = getErrorTextElement(input);
                if (errorEl) errorEl.textContent = "";
            });

            if (!email) {
                emailInput.classList.add("error");
                getErrorTextElement(emailInput).textContent = "Email is required.";
                isValid = false;
            } else if (!email.match(/^[^\s@]+@[^\s@]+\.[^\s@]+$/)) {
                emailInput.classList.add("error");
                getErrorTextElement(emailInput).textContent = "Enter a valid email address.";
                isValid = false;
            }

            if (!password) {
                passwordInput.classList.add("error");
                getErrorTextElement(passwordInput).textContent = "Password is required.";
                isValid = false;
            }

            if (!isValid) return;

            isSubmitting = true;
            submitBtn.disabled = true;
            spinner.classList.add("show");
            form.submit();
        });

        [emailInput, passwordInput].forEach((input) => {
            input.addEventListener("input", () => {
                input.classList.remove("error");
                const errorEl = getErrorTextElement(input);
                if (errorEl) errorEl.textContent = "";
            });
        });
    </script>
</body>
</html>
