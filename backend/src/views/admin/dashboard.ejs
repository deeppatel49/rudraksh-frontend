<%
const resolvedAdminBaseUrl = typeof adminBaseUrl !== "undefined" && adminBaseUrl ? adminBaseUrl : "";
const pageTitle = "Dashboard";
const activeView = "dashboard";
const generatedAt = dashboardData?.generatedAt ? new Date(dashboardData.generatedAt).toLocaleString("en-IN") : "Unavailable";
const productCount = Number(dashboardData?.totalProducts || 0);
const reviewCount = Number(dashboardData?.totalReviews || 0);
const messageCount = Number(dashboardData?.totalContactMessages || 0);
const averageRating = Number(dashboardData?.averageRating || 0).toFixed(1);
const pageCount = Number(dashboardData?.totalPages || 0);
const chatThreadCount = Number(dashboardData?.totalChatThreads || 0);
const chatMessageCount = Number(dashboardData?.totalChatMessages || 0);
const unreadChatCount = Number(dashboardData?.unreadChatCount || 0);
%>
<%- include("partials/admin-shell-start", { pageTitle, activeView, resolvedAdminBaseUrl, adminUser, cspNonce }) %>

<section class="page-head">
    <div class="page-copy">
        <span class="page-badge">Admin dashboard</span>
        <h2 class="page-title">Backend visibility without the clutter.</h2>
        <p>Track content readiness, operational signals, and the health of your backend-managed customer workflows from one screen.</p>
    </div>
    <div class="page-actions">
        <span class="info-pill">Last synced: <%= generatedAt %></span>
        <a class="ghost-btn" href="<%= resolvedAdminBaseUrl %>/admin/content/home">Edit homepage</a>
        <a class="btn-link" href="<%= resolvedAdminBaseUrl %>/admin/section/messages">Review messages</a>
    </div>
</section>

<% if (errorMessage) { %>
    <div class="message error">
        <div>
            <strong>Dashboard unavailable</strong>
            <p><%= errorMessage %></p>
        </div>
    </div>
<% } %>

<% if (dashboardData) { %>
    <section class="hero-card">
        <div class="hero-grid">
            <div class="hero-copy">
                <span class="metric-label">Operations summary</span>
                <h2>See what needs attention before customers feel it.</h2>
                <p>Inventory, customer feedback, inbound contact volume, and CMS records are surfaced here so backend work stays actionable.</p>
                <div class="button-row">
                    <a class="btn-link" href="<%= resolvedAdminBaseUrl %>/admin/section/products">Open products</a>
                    <a class="ghost-btn" href="<%= resolvedAdminBaseUrl %>/admin/content/about">Edit about page</a>
                </div>
                <p>Generated from backend services and repositories only. No frontend analytics dependency.</p>
            </div>

            <div class="metric-stack">
                <div class="metric-card">
                    <div class="metric-label">Content records</div>
                    <strong class="metric-value"><%= pageCount %></strong>
                    <p>CMS pages configured and available to the frontend fetch layer.</p>
                </div>
                <div class="metric-card">
                    <div class="metric-label">Average rating</div>
                    <strong class="metric-value"><%= averageRating %></strong>
                    <p>Review sentiment across customer submissions currently stored in backend data sources.</p>
                </div>
            </div>
        </div>
    </section>

    <div class="section-spacer"></div>

    <section class="stats-grid">
        <article class="stat-card">
            <div class="stat-card-head">
                <div>
                    <div class="table-label">Inventory</div>
                    <strong><%= productCount %></strong>
                </div>
                <span class="status-pill <%= productCount > 0 ? 'good' : 'empty' %>"><%= productCount > 0 ? 'Stocked' : 'Empty' %></span>
            </div>
            <p class="supporting-copy">Products currently available in the backend catalog dataset.</p>
        </article>

        <article class="stat-card">
            <div class="stat-card-head">
                <div>
                    <div class="table-label">Reviews</div>
                    <strong><%= reviewCount %></strong>
                </div>
                <span class="status-pill <%= reviewCount > 0 ? 'good' : 'empty' %>"><%= reviewCount > 0 ? 'Active' : 'Quiet' %></span>
            </div>
            <p class="supporting-copy">Customer review entries available for moderation and product insight.</p>
        </article>

        <article class="stat-card">
            <div class="stat-card-head">
                <div>
                    <div class="table-label">Messages</div>
                    <strong><%= messageCount %></strong>
                </div>
                <span class="status-pill <%= messageCount > 0 ? 'warning' : 'muted' %>"><%= messageCount > 0 ? 'Needs triage' : 'Clear' %></span>
            </div>
            <p class="supporting-copy">Contact form conversations waiting for review inside the backend console.</p>
        </article>

        <article class="stat-card">
            <div class="stat-card-head">
                <div>
                    <div class="table-label">Chat Threads</div>
                    <strong><%= chatThreadCount %></strong>
                </div>
                <span class="status-pill <%= unreadChatCount > 0 ? 'warning' : 'good' %>"><%= unreadChatCount > 0 ? 'Unread: ' + unreadChatCount : 'All caught up' %></span>
            </div>
            <p class="supporting-copy">Active customer conversations with <%= chatMessageCount %> total messages across threads.</p>
        </article>

        <article class="stat-card">
            <div class="stat-card-head">
                <div>
                    <div class="table-label">Pages</div>
                    <strong><%= pageCount %></strong>
                </div>
                <span class="status-pill <%= pageCount > 0 ? 'good' : 'empty' %>"><%= pageCount > 0 ? 'Ready' : 'Missing' %></span>
            </div>
            <p class="supporting-copy">Backend-managed page content records currently powering frontend page sections.</p>
        </article>
    </section>

    <section class="panel-card">
        <div class="panel-head">
            <div>
                <div class="table-label">Quick actions</div>
                <h3 class="section-title">Move from insight to action</h3>
                <p class="table-caption">Use these common admin routes to resolve the most likely follow-up tasks.</p>
            </div>
        </div>
        <div class="panel-body">
            <div class="quick-grid">
                <article class="quick-card">
                    <div class="summary-head">
                        <div>
                            <div class="table-label">Products</div>
                            <strong>Catalog maintenance</strong>
                        </div>
                    </div>
                    <p class="supporting-copy">Verify product naming, pricing, and category consistency in backend inventory data.</p>
                    <div class="stat-actions">
                        <a class="btn-link" href="<%= resolvedAdminBaseUrl %>/admin/section/products">Manage products</a>
                    </div>
                </article>
                <article class="quick-card">
                    <div class="summary-head">
                        <div>
                            <div class="table-label">Inbox</div>
                            <strong>Customer follow-up</strong>
                        </div>
                    </div>
                    <p class="supporting-copy">Review unread submissions and update message status without leaving the backend admin shell.</p>
                    <div class="stat-actions">
                        <a class="btn-link" href="<%= resolvedAdminBaseUrl %>/admin/section/messages">Open messages</a>
                    </div>
                </article>
                <article class="quick-card">
                    <div class="summary-head">
                        <div>
                            <div class="table-label">Chat Box</div>
                            <strong>Customer conversations</strong>
                        </div>
                    </div>
                    <p class="supporting-copy">Manage <%= chatThreadCount %> active customer chat threads and send personalized support messages.</p>
                    <div class="stat-actions">
                        <a class="btn-link" href="<%= resolvedAdminBaseUrl %>/admin/chat-box">View all chats</a>
                    </div>
                </article>
                <article class="quick-card">
                    <div class="summary-head">
                        <div>
                            <div class="table-label">CMS</div>
                            <strong>Page content updates</strong>
                        </div>
                    </div>
                    <p class="supporting-copy">Adjust hero content, story media, and metadata for the backend-managed pages.</p>
                    <div class="stat-actions">
                        <a class="btn-link" href="<%= resolvedAdminBaseUrl %>/admin/content/home">Home content</a>
                        <a class="ghost-btn" href="<%= resolvedAdminBaseUrl %>/admin/content/about">About content</a>
                    </div>
                </article>
            </div>
        </div>
    </section>

    <section class="panel-card">
        <div class="panel-head">
            <div>
                <div class="table-label">Overview table</div>
                <h3 class="section-title">Current backend data status</h3>
                <p class="table-caption">A compact audit of the modules this admin console depends on.</p>
            </div>
            <span class="info-pill"><%= generatedAt %></span>
        </div>
        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Module</th>
                        <th>Current value</th>
                        <th>Status</th>
                        <th>What it means</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Products</td>
                        <td><strong><%= productCount %></strong></td>
                        <td><span class="status-pill <%= productCount > 0 ? 'good' : 'empty' %>"><%= productCount > 0 ? 'Available' : 'Empty' %></span></td>
                        <td>Inventory records that power the frontend catalog and search flows.</td>
                    </tr>
                    <tr>
                        <td>Reviews</td>
                        <td><strong><%= reviewCount %></strong></td>
                        <td><span class="status-pill <%= reviewCount > 0 ? 'good' : 'empty' %>"><%= reviewCount > 0 ? 'Collecting' : 'No reviews' %></span></td>
                        <td>Customer-generated feedback available to help assess trust and product perception.</td>
                    </tr>
                    <tr>
                        <td>Messages</td>
                        <td><strong><%= messageCount %></strong></td>
                        <td><span class="status-pill <%= messageCount > 0 ? 'warning' : 'muted' %>"><%= messageCount > 0 ? 'Incoming' : 'Quiet' %></span></td>
                        <td>Contact submissions that can be marked read directly from the backend admin.</td>
                    </tr>
                    <tr>
                        <td>CMS pages</td>
                        <td><strong><%= pageCount %></strong></td>
                        <td><span class="status-pill <%= pageCount > 0 ? 'good' : 'empty' %>"><%= pageCount > 0 ? 'Configured' : 'Missing' %></span></td>
                        <td>Content records used by the frontend homepage and about page APIs.</td>
                    </tr>
                    <tr>
                        <td>Average rating</td>
                        <td><strong><%= averageRating %></strong></td>
                        <td><span class="status-pill <%= Number(averageRating) > 0 ? 'good' : 'empty' %>"><%= Number(averageRating) > 0 ? 'Rated' : 'No data' %></span></td>
                        <td>Computed review sentiment snapshot across submitted customer reviews.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>
<% } else if (!errorMessage) { %>
    <section class="panel-card">
        <div class="empty-state">
            <strong>No dashboard data yet</strong>
            <p>Once the backend repositories return data, this dashboard will summarize products, reviews, contact messages, and CMS records here.</p>
        </div>
    </section>
<% } %>

<%- include("partials/admin-shell-end", { cspNonce }) %>
