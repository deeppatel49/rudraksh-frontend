
<%
const resolvedAdminBaseUrl = typeof adminBaseUrl !== "undefined" && adminBaseUrl ? adminBaseUrl : "";
const pageTitle = sectionData?.title || "Admin Section";
const activeView = section || "";
const rowCount = Array.isArray(sectionData?.rows) ? sectionData.rows.length : 0;
const safeErrorMessage = typeof errorMessage !== "undefined" ? errorMessage : "";
const safeSuccessMessage = typeof successMessage !== "undefined" ? successMessage : "";
const hiddenColumns = pageTitle === "Login Data" ? ["Login Image", "Profile Image"] : [];
const visibleColumnIndexes = Array.isArray(sectionData?.columns)
    ? sectionData.columns
        .map((column, index) => ({ column, index }))
        .filter((entry) => !hiddenColumns.includes(String(entry.column || "").trim()))
        .map((entry) => entry.index)
    : [];
%>
<%- include("partials/admin-shell-start", { pageTitle, activeView, resolvedAdminBaseUrl, adminUser, cspNonce }) %>

<section class="page-head">
    <div class="page-copy">
        <span class="page-badge"><%= pageTitle %></span>
        <h2 class="page-title"><%= sectionData?.title || "Admin section" %></h2>
        <p><%= sectionData?.description || "Backend records and actions for this module." %></p>
    </div>
    <div class="page-actions">
        <span class="info-pill"><%= rowCount %> visible records</span>
        <a class="ghost-btn" href="<%= resolvedAdminBaseUrl %>/admin/dashboard">Back to dashboard</a>
    </div>
</section>

<% if (section === "products" && sectionData?.search) { %>
<section class="panel-card" style="margin-bottom: 16px; padding: 14px 16px;">
    <form method="GET" action="<%= sectionData.search.action %>" style="display:grid; grid-template-columns:minmax(220px, 1fr) auto auto; gap:10px; align-items:center;">
        <label style="display:flex; flex-direction:column; gap:4px; font-size:12px; font-weight:700; color:#475569; margin:0;">
            Catalog search
            <input
                type="text"
                name="q"
                value="<%= sectionData.search.query || '' %>"
                placeholder="Item name, company, generic, category"
                style="padding:9px 12px; border:1px solid #cbd5e1; border-radius:8px; font-size:13px; min-width:0;"
            >
        </label>
        <input type="hidden" name="limit" value="<%= sectionData.pagination?.limit || 100 %>">
        <button type="submit" class="btn" style="padding:9px 14px; min-height:auto;">Search</button>
        <% if (sectionData.search.query) { %>
            <a href="<%= sectionData.search.action %>?limit=<%= sectionData.pagination?.limit || 100 %>" class="ghost-btn" style="padding:9px 14px;">Clear</a>
        <% } %>
    </form>
</section>
<% } %>

<% if (section === "products" && sectionData?.productEditor) {
    const editor = sectionData.productEditor;
    const product = editor.product || {};
%>
<section class="panel-card" style="margin-bottom: 16px; padding: 16px;">
    <div class="panel-head" style="margin-bottom: 12px; gap: 12px; align-items: center;">
        <div>
            <div class="table-label">Edit product</div>
            <h3 class="section-title" style="margin-bottom: 0;"><%= product.name || product.itemName || "Product" %></h3>
        </div>
        <a href="<%= editor.cancelHref %>" class="ghost-btn">Close</a>
    </div>
    <form method="POST" action="<%= editor.action %>" style="display:grid; grid-template-columns:repeat(auto-fit, minmax(180px, 1fr)); gap:12px;">
        <input type="hidden" name="productId" value="<%= product.id || product.srNo || '' %>">
        <input type="hidden" name="page" value="<%= editor.page %>">
        <input type="hidden" name="limit" value="<%= editor.limit %>">
        <input type="hidden" name="q" value="<%= editor.query || '' %>">
        <label style="display:flex; flex-direction:column; gap:6px; font-weight:600; color:#0f172a;">
            Name
            <input type="text" name="itemName" value="<%= product.name || product.itemName || '' %>" required maxlength="200" style="padding:10px 12px; border:1px solid #cbd5e1; border-radius:8px; font-size:14px;">
        </label>
        <label style="display:flex; flex-direction:column; gap:6px; font-weight:600; color:#0f172a;">
            Company
            <input type="text" name="company" value="<%= product.manufacturer || product.company || '' %>" maxlength="200" style="padding:10px 12px; border:1px solid #cbd5e1; border-radius:8px; font-size:14px;">
        </label>
        <label style="display:flex; flex-direction:column; gap:6px; font-weight:600; color:#0f172a;">
            Generic
            <input type="text" name="generic" value="<%= product.composition || product.generic || '' %>" maxlength="200" style="padding:10px 12px; border:1px solid #cbd5e1; border-radius:8px; font-size:14px;">
        </label>
        <label style="display:flex; flex-direction:column; gap:6px; font-weight:600; color:#0f172a;">
            Item type
            <input type="text" name="itemType" value="<%= product.drug_type || product.itemType || '' %>" maxlength="100" style="padding:10px 12px; border:1px solid #cbd5e1; border-radius:8px; font-size:14px;">
        </label>
        <label style="display:flex; flex-direction:column; gap:6px; font-weight:600; color:#0f172a;">
            Category
            <input type="text" name="category" value="<%= product.category || '' %>" maxlength="100" style="padding:10px 12px; border:1px solid #cbd5e1; border-radius:8px; font-size:14px;">
        </label>
        <label style="display:flex; flex-direction:column; gap:6px; font-weight:600; color:#0f172a;">
            Pack
            <input type="text" name="pack" value="<%= product.pack_size || product.pack || '' %>" maxlength="100" style="padding:10px 12px; border:1px solid #cbd5e1; border-radius:8px; font-size:14px;">
        </label>
        <label style="display:flex; flex-direction:column; gap:6px; font-weight:600; color:#0f172a;">
            MRP
            <input type="number" name="mrp" value="<%= Number(product.price ?? product.mrp ?? 0) %>" min="0" step="0.01" required style="padding:10px 12px; border:1px solid #cbd5e1; border-radius:8px; font-size:14px;">
        </label>
        <div style="display:flex; align-items:end; gap:10px; flex-wrap:wrap;">
            <button type="submit" class="btn">Save product</button>
            <a href="<%= editor.cancelHref %>" class="ghost-btn">Cancel</a>
        </div>
    </form>
</section>
<% } %>

<% if (safeErrorMessage) { %>
    <div class="message error">
        <div>
            <strong>Action failed</strong>
            <p><%= safeErrorMessage %></p>
        </div>
    </div>
<% } %>

<% if (safeSuccessMessage) { %>
    <div class="message success">
        <div>
            <strong>Success</strong>
            <p><%= safeSuccessMessage %></p>
        </div>
    </div>
<% } %>

<% if (sectionData?.isProfileView) { 
    const profile = sectionData.profilePayload?.profile || {};
    const user = sectionData.profilePayload?.user || {};
%>
<section class="panel-card">
    <div class="panel-head">
        <div>
            <div class="table-label">Account</div>
            <h3 class="section-title">Admin Profile</h3>
            <p class="table-caption">Update your name, contact details, and optionally change email or password.</p>
        </div>
        <span class="info-pill"><%= user.createdAt ? new Date(user.createdAt).toLocaleDateString("en-IN") : "Member" %></span>
    </div>

    <form class="profile-form" method="POST" action="<%= resolvedAdminBaseUrl %>/admin/profile/update">
        <div class="form-grid">
            <label>
                Full name
                <input type="text" name="fullName" value="<%= profile.fullName || '' %>" required minlength="2" maxlength="80">
            </label>
            <label>
                Email
                <input type="email" name="email" value="<%= profile.email || user.email || '' %>" required>
            </label>
            <label>
                Mobile number
                <input type="tel" name="mobileNumber" value="<%= profile.mobileNumber || '' %>" required pattern="\\d{10,15}">
            </label>
            <label>
                Gender
                <select name="gender" required>
                    <option value="">Select</option>
                    <% ["male","female","other","prefer_not_to_say"].forEach(function(opt){ %>
                        <option value="<%= opt %>" <%= profile.gender === opt ? "selected" : "" %>><%= opt.replace(/_/g," ") %></option>
                    <% }); %>
                </select>
            </label>
            <label class="span-2">
                Address
                <input type="text" name="address" value="<%= profile.address || '' %>" required minlength="5" maxlength="300">
            </label>
            <label>
                City
                <input type="text" name="city" value="<%= profile.city || '' %>" required minlength="2" maxlength="80">
            </label>
            <label>
                Pincode
                <input type="text" name="pincode" value="<%= profile.pincode || '' %>" required pattern="[A-Za-z0-9\\-\\s]{4,10}">
            </label>
        </div>

        <details class="password-accordion">
            <summary>Change password (optional)</summary>
            <div class="form-grid">
                <label>
                    Current password
                    <input type="password" name="currentPassword" autocomplete="current-password">
                </label>
                <label>
                    New password
                    <input type="password" name="newPassword" minlength="6" maxlength="128" autocomplete="new-password">
                </label>
                <label>
                    Confirm new password
                    <input type="password" name="confirmPassword" minlength="6" maxlength="128" autocomplete="new-password">
                </label>
            </div>
        </details>

        <div class="form-actions" style="justify-content:flex-end;">
            <button type="submit" class="btn">Save changes</button>
        </div>
    </form>

    <div class="profile-customer-table">
        <div class="panel-head" style="margin-top:16px;">
            <div>
                <div class="table-label">Customer Profiles</div>
                <h3 class="section-title">Frontend user profiles</h3>
                <p class="table-caption">Profiles saved or edited by customers on the site.</p>
            </div>
            <span class="info-pill"><%= (sectionData.customerProfiles || []).length %> profiles</span>
        </div>

        <% if (sectionData.customerProfiles && sectionData.customerProfiles.length) { %>
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>City</th>
                            <th>Pincode</th>
                            <th>Updated</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% sectionData.customerProfiles.forEach(function(item){ %>
                            <tr>
                                <td><strong><%= item.fullName || "Customer" %></strong></td>
                                <td><%= item.email || "Not added" %></td>
                                <td><%= item.mobileNumber || item.whatsappNumber || "Not added" %></td>
                                <td><%= item.city || "Not added" %></td>
                                <td><%= item.pincode || "Not added" %></td>
                                <td><%= item.updatedAt ? new Date(item.updatedAt).toLocaleString("en-IN") : "N/A" %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="empty-state">
                <strong>No customer profiles yet.</strong>
                <p>Profiles created on the frontend will appear here.</p>
            </div>
        <% } %>
    </div>
</section>
<style>
    .profile-form .form-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 16px;
        margin-top: 16px;
    }
    .profile-form label {
        font-weight: 600;
        color: #0f172a;
        display: flex;
        flex-direction: column;
        gap: 6px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        padding: 12px;
        border-radius: 10px;
    }
    .profile-form input,
    .profile-form select {
        padding: 10px 12px;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        font-size: 14px;
    }
    .profile-form .span-2 {
        grid-column: span 2;
    }
    .password-accordion {
        margin-top: 12px;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 12px;
        background: #f8fafc;
    }
    .password-accordion summary {
        cursor: pointer;
        font-weight: 700;
        color: #0f172a;
    }
</style>
<% } else { %>
<% if (sectionData?.promoBanner) { %>
    <section class="hero-card">
        <div class="hero-grid">
            <div class="hero-copy">
                <span class="metric-label">Priority workflow</span>
                <h2><%= sectionData.promoBanner.prefix %> <%= sectionData.promoBanner.highlight %> <%= sectionData.promoBanner.suffix %></h2>
                <p>This shortcut is surfaced here because it is operationally linked to the current customer-facing flow.</p>
                <div class="button-row">
                    <a class="btn-link" href="<%= sectionData.promoBanner.actionHref %>"><%= sectionData.promoBanner.actionLabel %></a>
                </div>
            </div>
            <div class="metric-stack">
                <div class="metric-card">
                    <div class="metric-label">Module health</div>
                    <strong class="metric-value"><%= rowCount %></strong>
                    <p>Records currently available in this section for backend review or action.</p>
                </div>
            </div>
        </div>
    </section>
<% } %>
<% if (sectionData?.chatComposer) { %>
    <section class="panel-card">
        <div class="panel-head">
            <div>
                <div class="table-label">Seller chat</div>
                <h3 class="section-title"><%= sectionData.chatComposer.title %></h3>
                <p class="table-caption"><%= sectionData.chatComposer.subtitle %></p>
            </div>
        </div>

        <div class="seller-chat-layout">
            <div class="seller-chat-thread">
                <% if (Array.isArray(sectionData.chatComposer.messages) && sectionData.chatComposer.messages.length) { %>
                    <% sectionData.chatComposer.messages.forEach(function(item) { %>
                        <article class="seller-chat-bubble <%= item.senderRole === 'seller' ? 'seller' : 'customer' %>">
                            <strong><%= item.senderName || (item.senderRole === "seller" ? "Seller" : item.name || "Customer") %></strong>
                            <% if (item.message) { %>
                                <p><%= item.message %></p>
                            <% } %>
                            <% if (item.attachment && item.attachment.url) { %>
                                <a href="<%= item.attachment.url %>" class="seller-chat-attachment" target="_blank" rel="noopener noreferrer">
                                    <% if (String(item.attachment.mimeType || "").startsWith("image/")) { %>
                                        <img src="<%= item.attachment.url %>" alt="<%= item.attachment.fileName || 'Chat attachment' %>">
                                    <% } else { %>
                                        <span><%= item.attachment.fileName || "Attachment" %></span>
                                    <% } %>
                                </a>
                            <% } %>
                            <span><%= item.createdAt ? new Date(item.createdAt).toLocaleString("en-IN") : "N/A" %> · <%= item.status || "sent" %></span>
                        </article>
                    <% }) %>
                <% } else { %>
                    <div class="empty-state compact">
                        <strong>No chat messages yet.</strong>
                        <p>Send the first seller update to start this conversation.</p>
                    </div>
                <% } %>
            </div>

            <form method="POST" action="<%= sectionData.chatComposer.action %>" class="seller-chat-form" enctype="multipart/form-data" id="sellerChatForm">
                <input type="hidden" name="userId" value="<%= sectionData.chatComposer.userId || '' %>">
                <input type="hidden" name="email" value="<%= sectionData.chatComposer.email || '' %>">
                <input type="hidden" name="phone" value="<%= sectionData.chatComposer.phone || '' %>">
                <input type="hidden" name="name" value="<%= sectionData.chatComposer.name || '' %>">

                <label>
                    Message for user
                    <textarea name="message" rows="5" placeholder="Share payment confirmation, order updates, or support notes."></textarea>
                </label>

                <label>
                    Upload image
                    <input type="file" name="attachment" accept="image/*">
                </label>

                <button type="submit" class="btn">Send Message</button>
            </form>
        </div>
    </section>

    <script nonce="<%= cspNonce %>">
        const sellerChatForm = document.getElementById("sellerChatForm");

        if (sellerChatForm) {
            sellerChatForm.addEventListener("submit", (event) => {
                const messageField = sellerChatForm.querySelector('textarea[name="message"]');
                const attachmentField = sellerChatForm.querySelector('input[name="attachment"]');
                const hasMessage = Boolean(messageField && messageField.value.trim());
                const hasAttachment = Boolean(attachmentField && attachmentField.files && attachmentField.files.length);

                if (!hasMessage && !hasAttachment) {
                    event.preventDefault();
                    if (messageField) {
                        messageField.focus();
                    }
                    window.alert("Enter a message or choose an image before sending.");
                }
            });
        }
    </script>
<% } %>

<section class="panel-card">
    <div class="panel-head">
        <div>
            <div class="table-label"><%= sectionData?.tableTitle || "Data" %></div>
            <h3 class="section-title">Structured backend records</h3>
            <p class="table-caption">Readable on desktop, usable on mobile, and consistent across all admin sections.</p>
        </div>
        <span class="info-pill"><%= new Date().toLocaleString("en-IN") %></span>
    </div>

    <% if (rowCount > 0 && Array.isArray(sectionData?.columns) && sectionData.columns.length > 0) { %>
        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <% visibleColumnIndexes.forEach(function(columnIndex) { %>
                            <th><%= sectionData.columns[columnIndex] %></th>
                        <% }) %>
                    </tr>
                </thead>
                <tbody>
                    <% sectionData.rows.forEach(function(row) { %>
                        <tr>
                            <% visibleColumnIndexes.forEach(function(columnIndex) { const cell = row[columnIndex]; %>
                                <td>
                                    <% if (cell && typeof cell === "object" && cell.type === "link") { %>
                                        <a
                                            href="<%= cell.href %>"
                                            class="<%= cell.variant === 'primary' ? 'btn-link' : 'ghost-btn' %> <%= cell.className || '' %>"
                                            <%= cell.external ? 'target="_blank" rel="noopener noreferrer"' : '' %>
                                        ><%= cell.label %></a>
                                    <% } else if (cell && typeof cell === "object" && cell.type === "inline-link") { %>
                                        <a href="<%= cell.href %>" class="table-inline-link"><%= cell.label %></a>
                                    <% } else if (cell && typeof cell === "object" && cell.type === "label") { %>
                                        <span class="status-pill <%= cell.variant || 'muted' %>"><%= cell.label %></span>
                                    <% } else if (cell && typeof cell === "object" && cell.type === "preview") { %>
                                        <a href="<%= cell.href %>" class="file-preview" target="_blank" rel="noopener noreferrer">
                                            <% if (String(cell.mimeType || "").startsWith("image/")) { %>
                                                <img src="<%= cell.href %>" alt="<%= cell.label || 'Preview' %>" crossorigin="anonymous">
                                            <% } else { %>
                                                <span class="doc-preview">
                                                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 3h7l5 5v13a1 1 0 01-1 1H7a2 2 0 01-2-2V5a2 2 0 012-2z" />
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 3v5h5M9 13h6M9 17h4" />
                                                    </svg>
                                                    PDF
                                                </span>
                                            <% } %>
                                        </a>
                                    <% } else if (cell && typeof cell === "object" && cell.type === "status-select") { %>
                                        <form method="POST" action="<%= cell.action || `${resolvedAdminBaseUrl}/admin/messages/status` %>">
                                            <input type="hidden" name="messageId" value="<%= cell.key %>">
                                            <select name="status" class="status-select <%= cell.value || 'not-read' %>" onchange="this.form.submit()">
                                                <option value="read" <%= cell.value === "read" ? "selected" : "" %>>Read</option>
                                                <option value="not-read" <%= cell.value === "not-read" ? "selected" : "" %>>Not Read</option>
                                            </select>
                                        </form>
                                    <% } else { %>
                                        <%= cell %>
                                    <% } %>
                                </td>
                            <% }) %>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        <% if (sectionData?.pagination && sectionData.pagination.totalPages > 1) { %>
            <div class="panel-head" style="margin-top: 16px; align-items: center; gap: 12px;">
                <div>
                    <div class="table-label">Catalog pagination</div>
                    <p class="table-caption">
                        Total products: <%= sectionData.pagination.total %>.
                        Page <%= sectionData.pagination.currentPage %> of <%= sectionData.pagination.totalPages %>.
                        <%= sectionData.pagination.limit %> rows per page.
                    </p>
                </div>
                <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                    <% if (sectionData.pagination.hasPreviousPage) { %>
                        <a href="<%= sectionData.pagination.previousHref %>" class="ghost-btn">Previous</a>
                    <% } %>
                    <% if (sectionData.pagination.hasNextPage) { %>
                        <a href="<%= sectionData.pagination.nextHref %>" class="btn-link">Next</a>
                    <% } %>
                </div>
            </div>
        <% } %>
    <% } else { %>
        <div class="empty-state">
            <strong><%= sectionData?.emptyMessage || "No records found." %></strong>
            <p>This section is connected, but there is nothing actionable to display yet.</p>
        </div>
    <% } %>
</section>

<% } %>

<%- include("partials/admin-shell-end", { cspNonce }) %>
